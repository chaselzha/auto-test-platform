def send_build_notification(status, job_name, build_number, build_url, allure_url):
    """
    发送构建通知
    """
    emoji = "✅" if status == "SUCCESS" else "❌"
    status_text = "成功" if status == "SUCCESS" else "失败"

    message = f"""
    {emoji} Jenkins 构建 {status_text}

    📦 项目: {job_name}
    🔢 构建: #{build_number}
    📊 报告: {allure_url}
    🔗 详情: {build_url}
    """

    # 发送钉钉通知
    try:
        from utils.config import get_config
        config = get_config()
        webhook = config.get("notification.dingtalk.webhook")
        if webhook:
            notifier = DingTalkNotifier(webhook)
            notifier.send_markdown(
                title=f"Jenkins 构建 {status_text}",
                text=message
            )
    except Exception as e:
        logger.warning(f"钉钉通知发送失败: {e}")

    return message